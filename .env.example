# ─────────────────────────────────────────────────────────────
# RupeeFlow Environment Configuration
# ─────────────────────────────────────────────────────────────

# Network RPC URLs
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Deployer Private Key (NEVER commit the actual key)
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Contract Verification
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# USDC Contract Addresses
USDC_BASE_MAINNET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Multi-sig Escrow Signers
SIGNER_1=0x_SIGNER_ADDRESS_1
SIGNER_2=0x_SIGNER_ADDRESS_2
SIGNER_3=0x_SIGNER_ADDRESS_3

# Escrow Configuration
ESCROW_THRESHOLD=2
REFUND_TIMELOCK=86400

# Fee Configuration (basis points)
BASE_FEE_RATE=30

# Frontend
VITE_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
VITE_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID
